{
  "name": "catvox-functions",
  "version": "1.0.0",
  "description": "CatVox AI — Firebase Cloud Functions (2nd Gen)",
  "scripts": {
    "build": "mkdir -p assets && cp ../docs/systemInstruction.md assets/systemInstruction.md && tsc",
    "build:integration": "tsc -p tsconfig.integration.json",
    "build:watch": "tsc --watch",
    "test": "npm run test:unit",
    "test:unit": "npm run build && node --test test/*.test.js",
    "test:integration": "npm run build:integration && node lib-integration/integration/verifyQuotaContract.js --confirm",
    "serve": "npm run build && firebase emulators:start --only functions",
    "predeploy": "npm run build"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google-cloud/firestore": "^7.11.6",
    "@google-cloud/storage": "^7.0.0",
    "@google/genai": "^1.50.1",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^7.2.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
