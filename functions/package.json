{
  "name": "catvox-functions",
  "version": "1.0.0",
  "description": "CatVox AI — Firebase Cloud Functions (2nd Gen)",
  "scripts": {
    "build": "mkdir -p assets && cp ../docs/Instructions.md assets/instructions.md && tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "predeploy": "npm run build"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google-cloud/storage": "^7.0.0",
    "@google-cloud/vertexai": "^1.0.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^7.2.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
